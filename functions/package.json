{
  "name": "japa-functions",
  "version": "1.0.0",
  "description": "Japa Backend - Firebase Cloud Functions",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed": "npm run build && node lib/scripts/seed-questions.js",
    "seed:emulator": "npm run build && FIRESTORE_EMULATOR_HOST=localhost:8080 node lib/scripts/seed-questions.js",
    "seed:portal": "npm run build && node lib/scripts/seed-portal.js",
    "seed:portal:emulator": "npm run build && FIRESTORE_EMULATOR_HOST=localhost:8080 node lib/scripts/seed-portal.js",
    "lint": "eslint --ext .ts src/",
    "lint:fix": "eslint --ext .ts src/ --fix",
    "clean": "rm -rf lib"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.27",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  },
  "private": true
}
